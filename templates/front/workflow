name: Build and Release Front

on:
  push:
    branches: ['main']

env:
  FRONT_NAME: meu-front

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    defaults:
      run:
        working-directory: front

    steps:
      - uses: actions/checkout@v4

      - uses: oven-sh/setup-bun@v2

      - run: bun install --frozen-lockfile

      - run: bun run build

      - name: Empacota o build
        run: tar -czf ../${{ env.FRONT_NAME }}.tar.gz -C dist .

      - name: Cria Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ env.FRONT_NAME }}-${{ github.sha }}
          files: ${{ env.FRONT_NAME }}.tar.gz
          make_latest: true
