name: Build and Release Front

on:
  push:
    branches: ['main']

env:
  FRONT_NAME: meu-front

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: write  # pra criar release

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: 20

      - run: npm ci
      - run: npm run build

      - name: Empacota o build
        run: tar -czf ${{ env.FRONT_NAME }}.tar.gz -C dist .

      - name: Cria Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ env.FRONT_NAME }}-${{ github.sha }}
          files: ${{ env.FRONT_NAME }}.tar.gz
          make_latest: true

  notify-server:
    needs: build
    runs-on: ubuntu-latest
    steps:
      - name: Call deploy webhook
        # ... mesmo webhook que você já usa
